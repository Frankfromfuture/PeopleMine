// PeopleMine 人迈 — 人脉管理工具
// Web Demo 1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── 用户与认证 ────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  image     String?
  industry  String?
  role      String?
  goal      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
  journeys Journey[]
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// ─── 核心业务模型 ──────────────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name   String
  wechat String?
  phone  String?
  email  String?

  spiritAnimal SpiritAnimal?
  relationRole RelationRole

  tags     String[]
  industry String?
  company  String?
  title    String?

  trustLevel  Int?
  temperature Temperature?
  energyScore Int          @default(50)

  notes String? @db.Text

  lastContactedAt DateTime?

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions Interaction[]
  relationsA   ContactRelation[] @relation("ContactA")
  relationsB   ContactRelation[] @relation("ContactB")

  @@index([userId])
  @@index([userId, relationRole])
  @@index([userId, spiritAnimal])
}

model ContactRelation {
  id           String  @id @default(cuid())
  contactIdA   String
  contactIdB   String
  relationDesc String?
  createdAt    DateTime @default(now())

  contactA Contact @relation("ContactA", fields: [contactIdA], references: [id], onDelete: Cascade)
  contactB Contact @relation("ContactB", fields: [contactIdB], references: [id], onDelete: Cascade)

  @@unique([contactIdA, contactIdB])
  @@index([contactIdA])
  @@index([contactIdB])
}

model Interaction {
  id        String          @id @default(cuid())
  contactId String
  type      InteractionType
  content   String          @db.Text
  date      DateTime        @default(now())
  createdAt DateTime        @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([date])
}

model Journey {
  id         String   @id @default(cuid())
  userId     String
  goal       String   @db.Text
  aiAnalysis String?  @db.Text
  pathData   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── 枚举 ──────────────────────────────────────────────────

enum SpiritAnimal {
  LION
  FOX
  BEAR
  CHAMELEON
  EAGLE
  DOLPHIN
  OWL
  SKUNK
}

enum RelationRole {
  BIG_INVESTOR
  GATEWAY
  ADVISOR
  THERMOMETER
  LIGHTHOUSE
  COMRADE
}

enum Temperature {
  COLD
  WARM
  HOT
}

enum InteractionType {
  MEETING
  CALL
  EMAIL
  MESSAGE
  EVENT
  OTHER
}
