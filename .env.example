# PeopleMine 人迈 — 环境变量模板
# 复制此文件为 .env 并填写实际值

# ─── 数据库 ───────────────────────────────────────────────
# PostgreSQL 连接串（推荐使用 Supabase）
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# ─── NextAuth ─────────────────────────────────────────────
# 生成随机密钥：openssl rand -base64 32
NEXTAUTH_SECRET=
# 本地开发：http://localhost:3000
NEXTAUTH_URL=

# ─── OAuth 登录（至少配置一个）─────────────────────────────
# Google OAuth：https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI 分析（人脉航程 F3）────────────────────────────────
# Anthropic Claude API：https://console.anthropic.com/
ANTHROPIC_API_KEY=
