# PeopleMine 人迈 — 环境变量模板
# 复制此文件为 .env 并填写实际值

# ─── 数据库 ───────────────────────────────────────────────
# PostgreSQL 连接串（推荐使用 Supabase）
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# ─── Session 加密密钥 ─────────────────────────────────────
# 生成命令：openssl rand -base64 32（至少32字符）
SESSION_SECRET=

# ─── 阿里云短信服务 ────────────────────────────────────────
# 阿里云控制台 → 访问控制 → AccessKey 管理
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
# 短信服务 → 签名管理（如：人迈）
ALIYUN_SMS_SIGN_NAME=
# 短信服务 → 模板管理（如：SMS_xxxxxxxx）
ALIYUN_SMS_TEMPLATE_CODE=

# ─── AI 分析（人脉航程 F3）────────────────────────────────
# Qwen（DashScope OpenAI-compatible）：https://dashscope.aliyuncs.com/
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
